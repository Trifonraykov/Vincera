# === Vincera Bot Configuration ===

# OpenRouter API key (will be encrypted at rest after first run)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Company identity
COMPANY_NAME=MyCompany
AGENT_NAME=vincera
COMPANY_ID=

# Supabase connection (service key will be encrypted at rest)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# File system
HOME_DIR=~/VinceraHQ

# Model selection
ORCHESTRATOR_MODEL=anthropic/claude-opus-4-5
AGENT_MODEL=anthropic/claude-sonnet-4-5

# Ghost mode (days of observation before active deployment)
GHOST_MODE_DAYS=7
